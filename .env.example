# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pastor_tracking

# JWT
JWT_SECRET=pastor_jwt_secret_2026

# CORS
# Para desarrollo local: No es necesario configurar FRONTEND_URL,
# se usa automáticamente: localhost:3000, localhost:3001, localhost:5173, 127.0.0.1:3000
# Para producción: Configurar NODE_ENV=production y FRONTEND_URL con los dominios permitidos
# Múltiples dominios: FRONTEND_URL=https://domain1.com,https://domain2.com
FRONTEND_URL=http://localhost:3001

# BillionMail SMTP (servidor de correo self-hosted)
# Ver: docs/SETUP_EMAIL.md para instrucciones de configuración
MAIL_HOST=mail.tudominio.com
MAIL_PORT=587
MAIL_USER=no-reply@tudominio.com
MAIL_PASS=tu_password_smtp
MAIL_FROM="Sistema Pastoral <no-reply@tudominio.com>"
